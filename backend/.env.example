# Server
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgres://election_admin:CHANGE_ME@localhost:5432/election
# DATABASE_URL_FALLBACK=postgres://user:pass@host:5432/db  # used when primary is unreachable

# Blockchain
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_SECOND_KEY
RPC_URL_3=https://eth-sepolia.g.alchemy.com/v2/YOUR_THIRD_KEY
RPC_URL_FALLBACK=https://ethereum-sepolia.publicnode.com
CONTRACT_ADDRESS=0xB38fE25e22E3442A7661B4EB2B9C3015A513B358
CONTRACT_ADDRESS_V3=0x470Bf74D617fbd433A8Fd3a8B13c70601656Ac28
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# IPFS (Pinata) — optional, only needed if you upload images
PINATA_KEY=
PINATA_SECRET=

# ⚠️ REQUIRED for Student Portal auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Email (SMTP) — required for sending registration codes via email.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Election Committee <noreply@election.example.com>

# Public URL the browser uses to reach this backend.
# Used to build absolute URLs for locally-stored profile photos
# (only relevant when Pinata is NOT configured; if PINATA_KEY + PINATA_SECRET
# are set, photos are pinned to IPFS and this var is ignored).
# Examples:
#   http://localhost:5000                  (local dev)
#   https://api.your-election.example.com  (production)
# Leave blank in dev to default to http://localhost:5000.
# BACKEND_PUBLIC_URL=
